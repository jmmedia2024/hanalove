{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["super_admin", "content_manager", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Notice": {
      "title": "Notice",
      "description": "Notice board post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "views": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "Gallery board post with multiple images",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrls": { 
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "maxItems": 10
        },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrls", "authorId", "createdAt"]
    },
    "Donation": {
      "title": "Donation",
      "description": "Donation record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["regular", "one-time"] },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["donorName", "amount", "type", "createdAt"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "description": "Volunteer application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Visitor contact/inquiry submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "answered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "message", "createdAt"]
    },
    "Page": {
      "title": "Page",
      "description": "Dynamic page content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "path": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "path", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "Notice board collection"
    },
    "/gallery/{galleryId}": {
      "schema": "Gallery",
      "description": "Gallery board collection"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Donations collection"
    },
    "/volunteers/{volunteerId}": {
      "schema": "Volunteer",
      "description": "Volunteer applications collection"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Visitor contact/inquiry submissions"
    },
    "/pages/{pageId}": {
      "schema": "Page",
      "description": "Dynamic pages collection"
    }
  }
}


